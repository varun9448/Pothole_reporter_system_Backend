            {
              "key": "photo",
              "type": "file",
              "src": ""
            },
            {
              "key": "latitude",
              "value": "12.9716",
              "type": "text"
            },
            {
              "key": "longitude",
              "value": "77.5946",
              "type": "text"
            },
            {
              "key": "description",
